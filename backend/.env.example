# Frontend API base URL
VITE_API_BASE_URL=http://localhost:4000
VITE_SHOW_DEV_OTP_PREVIEW=false

# Backend runtime
API_PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:3000
