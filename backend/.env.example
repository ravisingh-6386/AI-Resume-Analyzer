# Other providers (Brevo/Mailtrap/SendGrid/etc.): use provider SMTP host/port and password/token.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_SERVICE=
MAIL_USER=Ravisingh98199@gmail.com
MAIL_PASSWORD=your-smtp-password
# Backward compatibility (optional):
# MAIL_APP_PASSWORD=your-gmail-app-password
MAIL_FROM="AI Resume Analyzer <Ravisingh98199@gmail.com>"
